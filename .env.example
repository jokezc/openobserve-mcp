OPENOBSERVE_BASE_URL=http://192.168.1.54:5080
# Optional. Defaults to default when omitted.
OPENOBSERVE_ORG_ID=default
OPENOBSERVE_USERNAME=
OPENOBSERVE_PASSWORD=

# Optional limits and defaults
OPENOBSERVE_DEFAULT_LOG_STREAM=
OPENOBSERVE_DEFAULT_TRACE_STREAM=default
OPENOBSERVE_DEFAULT_LOG_COLUMNS=_timestamp,message
OPENOBSERVE_DEFAULT_LOOKBACK=3d
OPENOBSERVE_DEFAULT_LOG_ROWS=50
OPENOBSERVE_DEFAULT_STREAM_ROWS=100
OPENOBSERVE_LOG_MESSAGE_CHAR_LIMIT=2000
OPENOBSERVE_LOG_NO_TRUNCATE_KEYWORDS=ERROR,WARN
OPENOBSERVE_MAX_RANGE=31d
OPENOBSERVE_MAX_LOG_ROWS=1000
OPENOBSERVE_MAX_STREAM_ROWS=500
OPENOBSERVE_MASK_FIELDS=password,passwd,pwd,token,secret,authorization,api_key,apikey,access_token,refresh_token
